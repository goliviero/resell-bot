# Dashboard authentication (required for online deployment)
DASHBOARD_USER=admin
DASHBOARD_PASS=changeme

# Telegram notifications (get from @BotFather)
# TELEGRAM_BOT_TOKEN=123456:ABC-DEF...
# TELEGRAM_CHAT_ID=123456789

# Optional: override default database path (default: data/resell_bot.db)
# DB_PATH=data/resell_bot.db

# Optional: encryption key for SMTP passwords (auto-generated if missing)
# ENCRYPTION_KEY=your-fernet-key-here

# Optional: session secret (auto-generated if missing, sessions reset on restart)
# SESSION_SECRET=your-hex-secret-here

# Optional: proxy for HTTP requests
# HTTP_PROXY=http://proxy:8080
# HTTPS_PROXY=http://proxy:8080
